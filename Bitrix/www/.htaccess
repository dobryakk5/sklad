  RewriteCond %{REQUEST_URI} ^(.*/[^/\.]+)$
  RewriteCond %{THE_REQUEST} !api/*
  RewriteCond %{THE_REQUEST} !urest/*
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1/ [R=301,L]

#  RewriteCond %{REQUEST_FILENAME} !-f
#  RewriteCond %{REQUEST_FILENAME} !-l
#  RewriteCond %{REQUEST_FILENAME} !-d
 # RewriteCond %{REQUEST_URI} ^(.*/[^/\.]+)$
  #RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1/ [R=301,L]
##################################################################
	RewriteCond %{HTTP_HOST} ^www\.alfasklad\.ru:443$ [NC]
	RewriteRule ^(.*)$ https://alfasklad.ru/$1 [R=301,L]

#	RewriteCond %{SERVER_NAME} !^(www\.)?alfasklad\.ru$
#	RewriteRule ^ - [F]
##################################################################
	#редирект с index.php
  RewriteCond %{REQUEST_URI} ^(.*)index\.php$
  RewriteCond %{THE_REQUEST} !bitrix/*
  RewriteRule ^ %1 [R=301,L]

#	RewriteRule ^about/useful_for_rental /blog/$1 [R=301,L]

#редирект с index.php для главной
#	RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.php\ HTTP/
#	RewriteRule ^index\.php$ https://alfasklad.ru/ [R=301,L]

	# ASPRO_ROBOTS Serve robots.txt with robots.php only if the latter exists
	#RewriteCond %{REQUEST_FILENAME} robots.txt
	#RewriteCond %{DOCUMENT_ROOT}/robots.php -f
	#RewriteRule ^(.*)$ /robots.php [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !/bitrix/urlrewrite.php$
  RewriteRule ^(.*)$ /bitrix/urlrewrite.php [L]
  RewriteRule .* - [E=REMOTE_USER:%{HTTP:Authorization}]
</IfModule>

<IfModule mod_dir.c>
  DirectoryIndex index.php index.html
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive on
  ExpiresByType image/jpeg "access plus 3 day"
  ExpiresByType image/gif "access plus 3 day"
  ExpiresByType image/png "access plus 3 day"
  ExpiresByType text/css "access plus 3 day"
  ExpiresByType application/javascript "access plus 3 day"
</IfModule>

